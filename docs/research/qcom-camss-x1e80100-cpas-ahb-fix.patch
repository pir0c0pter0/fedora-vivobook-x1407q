+
+static bool csid_skip_clock_rate_vote(struct csid_device *csid,
+				      const char *clock_name)
+{
+	if (!of_device_is_compatible(csid->camss->dev->of_node,
+				     "qcom,x1e80100-camss"))
+		return false;
+
+	/*
+	 * x1e80100 emits an RCG WARN when qcom_camss tries to reprogram the
+	 * slow AHB clock through the CPAS AHB branch at stream-on time. The
+	 * camera continues to stream correctly without this explicit rate vote,
+	 * so keep the existing firmware/kernel default rate instead.
+	 */
+	return !strcmp(clock_name, "cpas_ahb");
+}
